# ==========================================
# XRAY BINARY & PATHS
# ==========================================
XRAY_BIN=/root/goduser/xray_user
DATA_DIR=./data

# ==========================================
# INBOUND CONFIGURATION (WITH AUTH)
# ==========================================
VLESS_IN_PORT=443
SOCKS_IN_PORT=80

# ==========================================
# OUTBOUND FAILOVER CONFIGURATION (NO AUTH)
# ==========================================
# Primary SOCKS Outbound
SOCKS_OUT_1_HOST=127.0.0.1
SOCKS_OUT_1_PORT=2080

# Secondary SOCKS Outbound (Fallback)
SOCKS_OUT_2_HOST=127.0.0.1
SOCKS_OUT_2_PORT=2081


SOCKS_OUT_3_HOST=127.0.0.1
SOCKS_OUT_3_PORT=2082

# ==========================================
# XRAY API & SYSTEM
# ==========================================
XRAY_API_SERVER=127.0.0.1:4343
POLL_INTERVAL_MS=10000
DEBUG_TRAFFIC=true

# ==========================================
# WEB UI DASHBOARD
# ==========================================
WEB_PORT=3000
WEB_ADMIN_USER=admin
WEB_ADMIN_PASS=admin
